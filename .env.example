# Copier ce fichier en `.env` à la racine (ne jamais committer `.env`).
# Sur Vercel : Settings → Environment Variables (mêmes noms, environnement Production).

VITE_SUPABASE_URL=https://VOTRE_REF.supabase.co
VITE_SUPABASE_ANON_KEY=votre_cle_anon_publique

# Sauvegarde complète : npm run backup  (code ZIP + base SQL + copie .env)
# Sauvegarde base seule : npm run backup:supabase
# Mot de passe PostgreSQL (Dashboard → Database → Reset password) :
SUPABASE_DB_PASSWORD=
# Optionnel — pooler session (défaut : aws-1-eu-west-3.pooler.supabase.com)
# SUPABASE_DB_POOLER_HOST=aws-1-eu-west-3.pooler.supabase.com
# Ou URI complète :
# SUPABASE_DB_URL=postgresql://postgres.[ref]:[MOT_DE_PASSE]@aws-1-eu-west-3.pooler.supabase.com:5432/postgres

# Détourage fond blanc → PNG transparent (scripts/make-avatars-transparent.mjs)
# THRESHOLD=248   — plus haut = plus conservateur (défaut 248)
# CONCURRENCY=4   — parallélisme upload
# LIMIT=20        — test sur N fichiers

# Génération avatars (scripts/generate-avatars.js)
SUPABASE_SERVICE_ROLE_KEY=
HF_TOKEN=
# Optionnel — pause aléatoire après chaque upload réussi (millisecondes)
# HF_THROTTLE_MIN_MS=5000
# HF_THROTTLE_MAX_MS=40000
# (HF_THROTTLE_MS=5000 reste accepté comme alias de MIN)
# HF_ERROR_BACKOFF_BASE_MS=300000
# HF_ERROR_BACKOFF_MAX_MS=3600000
# HF_MAX_CONSECUTIVE_ERRORS=5
EMAIL_USER=
EMAIL_APP_PASSWORD=

# E-mails transactionnels (Edge Functions) — Resend (envoi sortant)
# Réception hello@aimediart.com : ImprovMX (MX DNS — ne pas modifier)
# Clé : https://resend.com/api-keys
# RESEND_API_KEY=re_...
# NOTIFY_FROM_EMAIL=hello@aimediart.com
# QUOTE_NOTIFY_EMAIL=hello@aimediart.com
# ADMIN_EMAIL=

# Coûts OVH — secrets Supabase Edge Functions (pas VITE_*)
# Token : https://eu.api.ovh.com/createToken/?GET=/me/bill&GET=/me/bill/*
# OVH_APP_KEY=
# OVH_APP_SECRET=
# OVH_CONSUMER_KEY=
# OVH_ENDPOINT=ovh-eu

# Coûts Google — secrets Supabase Edge Functions (pas VITE_*)
# Voir docs/GOOGLE-BILLING-COSTS.md
# GOOGLE_CLOUD_PROJECT_ID=
# GOOGLE_BILLING_BQ_DATASET=billing_export
# GOOGLE_BILLING_BQ_TABLE=gcp_billing_export_resource_v1_XXXXX
# GOOGLE_BILLING_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
AVATAR_NOTIFY_EMAIL=fadu57@gmail.com
