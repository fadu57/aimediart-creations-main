{
  "version": 2,
  "builds": [
    {
      "src": "api/export/statistics-pdf.ts",
      "use": "@vercel/node"
    },
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/pdf-export/export/statistics-pdf",
      "dest": "/api/export/statistics-pdf"
    },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ],
  "functions": {
    "api/export/statistics-pdf.ts": {
      "maxDuration": 120,
      "memory": 3008,
      "includeFiles": "node_modules/@sparticuz/chromium/**"
    }
  }
}
